{
  "extraKnownMarketplaces": {
    "llm-wiki": {
      "source": {
        "source": "github",
        "repo": "happytk/llm-wiki-rr"
      }
    }
  },
  "enabledPlugins": {
    "wiki@llm-wiki": true
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/wiki-workspace.sh\"",
            "timeout": 20,
            "statusMessage": "Configuring llm-wiki workspace (single-graph roam mode: wiki-s)"
          }
        ]
      }
    ]
  }
}
